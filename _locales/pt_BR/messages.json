    "message": "Erro"
  },
  "toolbarTrashLabel": {
    "message": "Esvaziar Lixeira"
  },
  "toolbarSpamLabel": {
    "message": "Esvaziar Spam"
  },
  "toolbarBothLabel": {
    "message": "Esvaziar Lixeira e Spam"
  },
  "notifyMessagesDeleted": {
    "message": "$COUNT$ mensagens excluídas.",
