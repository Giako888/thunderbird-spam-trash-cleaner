  "successSpam": {
    "message": "垃圾邮件已清空！"
  },
  "successBoth": {
    "message": "废纸篓和垃圾邮件已清空！"
  },
  "successDetail": {
    "message": "✅ $MSG$（已删除 $COUNT$ 封邮件）",
