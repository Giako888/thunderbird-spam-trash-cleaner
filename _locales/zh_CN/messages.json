  "toolbarTrashLabel": {
    "message": "清空废纸篓"
  },
  "toolbarSpamLabel": {
    "message": "清空垃圾邮件"
  },
  "toolbarBothLabel": {
    "message": "清空废纸篓和垃圾邮件"
  },
  "notifyMessagesDeleted": {
    "message": "已删除 $COUNT$ 封邮件。",
    "placeholders": { "count": { "content": "$1" } }
  },
  "notifyDeletedWithErrors": {
    "message": "已删除 $COUNT$ 封，但有错误：\n$ERRORS$",
