    "message": "Sem resposta do script de fundo"
  },
  "errorInvalidResponse": {
    "message": "Resposta inválida do script de fundo"
  },
  "successTrash": {
    "message": "Lixeira esvaziada!"
  },
  "successSpam": {
    "message": "Spam esvaziado!"
  },
  "successBoth": {
    "message": "Lixeira e Spam esvaziados!"
  },
  "successDetail": {
    "message": "✅ $MSG$ ($COUNT$ mensagens excluídas)",
